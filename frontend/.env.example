# Auth provider selector: clerk | cognito
NEXT_PUBLIC_AUTH_PROVIDER=clerk

# Clerk auth (when NEXT_PUBLIC_AUTH_PROVIDER=clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/projects
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/projects

# Cognito auth (when NEXT_PUBLIC_AUTH_PROVIDER=cognito).
# Phase 5: tokens are exchanged server-side and stored in httpOnly cookies by
# Amplify's Next.js adapter (requires Cognito Managed Login).
# Domain is the host only (no https://).
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_USER_POOL_CLIENT_ID=
NEXT_PUBLIC_COGNITO_DOMAIN=
# App origin used to build OAuth redirect URLs and decide cookie `secure`.
# Use http://localhost:3000 in dev, https://yourdomain in prod.
AMPLIFY_APP_ORIGIN=http://localhost:3000
# Add these exact URLs to the Cognito app client's allow-list:
#   sign-in callback : ${AMPLIFY_APP_ORIGIN}/api/auth/sign-in-callback
#   sign-out callback: ${AMPLIFY_APP_ORIGIN}/api/auth/sign-out-callback

NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_POSTHOG_ANONYMOUS=
NEXT_PUBLIC_LANGFUSE_USER_URL=
