# =============================================================================
# AUTH PROVIDER CONFIGURATION
# =============================================================================
# REQUIRED: Set the auth provider to use
# Options: 'clerk' or 'keycloak'
# The app will fail to start if this is not set
NEXT_PUBLIC_AUTH_PROVIDER=clerk

# =============================================================================
# CLERK CONFIGURATION (required when NEXT_PUBLIC_AUTH_PROVIDER=clerk)
# =============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# =============================================================================
# KEYCLOAK CONFIGURATION (required when NEXT_PUBLIC_AUTH_PROVIDER=keycloak)
# =============================================================================
# Keycloak server URL (e.g., https://keycloak.example.com)
NEXT_PUBLIC_KEYCLOAK_URL=
# Keycloak realm name
NEXT_PUBLIC_KEYCLOAK_REALM=
# Keycloak client ID (must be a public OIDC client)
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=
