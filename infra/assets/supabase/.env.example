# .env.example — documents every variable consumed by docker-compose.yml.
# The real .env is written by init.sh at boot from Secrets Manager values.
# Do NOT commit a populated .env to source control.

POSTGRES_HOST=your-rds-endpoint.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_PASSWORD=changeme

JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
JWT_EXPIRY=3600

SECRET_KEY_BASE=your-secret-key-base-min-64-chars
DB_ENC_KEY=your-db-enc-key-32-chars

SITE_URL=http://supabase.staging.policyatlas.local:8000
API_EXTERNAL_URL=http://supabase.staging.policyatlas.local:8000

STORAGE_S3_BUCKET=your-supabase-storage-bucket-name
AWS_DEFAULT_REGION=eu-west-2

STUDIO_DEFAULT_ORGANIZATION=Policy Atlas
STUDIO_DEFAULT_PROJECT=Policy Atlas
# Dashboard basic-auth (set a strong password before deploying)
DASHBOARD_PASSWORD=changeme

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=
SMTP_SENDER_NAME=Policy Atlas
